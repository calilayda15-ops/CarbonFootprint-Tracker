# --- LOGISTICS SUSTAINABILITY ANALYTICS ---

# COMMON LIMIT (Karbon Kotası)
carbon_limit = 500000  # 500kg CO2 limit

# 1. SCENARIO: HEAVY DUTY TRUCK (Tır)
distance_heavy = 1000
emission_heavy = 900
total_heavy = distance_heavy * emission_heavy

print("SCENARIO 1: Heavy Duty Truck")
print("Total CO2:", total_heavy, "grams")

if total_heavy > carbon_limit:
    print("RESULT: ALERT! High Carbon Risk - Limit Exceeded")
else:
    print("RESULT: Sustainable Route - Approved")

print("-" * 30) # Araya çizgi çeker

# 2. SCENARIO: MEDIUM TRUCK (Kamyon)
distance_medium = 1000
